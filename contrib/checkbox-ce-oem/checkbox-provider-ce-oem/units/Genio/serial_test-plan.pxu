id: genio-serial-full
unit: test plan
_name: Genio Serial tests
_description: Full Genio Serial tests for devices
include:
nested_part:
    genio-serial-manual
    genio-serial-automated

id: genio-serial-manual
unit: test plan
_name: Genio Serial manual tests
_description: Manual Genio Serial tests for devices
include:
    genio-serial/uart1-micro-b-.*
    genio-serial/uart2-micro-b-.*

id: genio-serial-automated
unit: test plan
_name: Genio Serial auto tests
_description: Automated Genio Serial tests for devices
bootstrap_include:
    genio_device_soc
include:
    genio-serial/uart1-rpi-hat-loopback-.*
    genio-serial/uart1-j52-loopback-.*
    genio-serial/uart2-rpi-hat-loopback-.*
