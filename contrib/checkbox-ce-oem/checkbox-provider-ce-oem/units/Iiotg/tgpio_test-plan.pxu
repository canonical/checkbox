id: iiotg-tgpio-full
_name: Iiotg TGPIO Tests (Full)
unit: test plan
include:
nested_part:
    iiotg-tgpio-manual
    iiotg-tgpio-automated

id: iiotg-tgpio-manual
_name: Iiotg TGPIO Tests (Manual)
unit: test plan
include:
    iiotg-tgpio/ptp-virtual-device-node-detect
    iiotg-tgpio/ptp-time-check-send-.*
    iiotg-tgpio/ptp-time-check-receive-.*
bootstrap_include:
    iiotg-tgpio/ptp-device-node-info

id: iiotg-tgpio-automated
_name: Iiotg TGPIO Tests (Automated)
unit: test plan
include:
    iiotg-tgpio/ptp-virtual-device-node-detect
    iiotg-tgpio/intc-driver-loaded
    iiotg-tgpio/ptp-time-check-loopback-.*
bootstrap_include:
    iiotg-tgpio/ptp-device-node-info
