template-id: iiotg-tsn/ieee802-1qav/credit-based-shaper
id: iiotg-tsn/ieee802-1qav/credit-based-shaper-{{ interface }}
category_id: iiotg-tsn
_summary: Credit-Based Shaper on {{ interface }}
depends:
    iiotg-tsn/tsn-detected
imports: from com.canonical.plainbox import manifest
requires:
    manifest.has_iiotg_tsn == 'True'
plugin: shell
user: root
_purpose:
    To check if the system can send packets in the certain rate
environ:
    TSN_CREDIT_BASED_SHAPER_TESTING_TIME
command:
    iiotg_tsn.py --run credit_based_shaper --interface {{ interface }}  -t "${TSN_CREDIT_BASED_SHAPER_TESTING_TIME:-10}" --server-ip {{ server_ip }}

unit: template
template-resource: iiotg-tsn/tsn-device-ip-match
template-unit: job
template-engine: jinja2
template-id: iiotg-tsn/ieee802-1qbv/traffic-scheduling
id: iiotg-tsn/ieee802-1qbv/traffic-scheduling-{{ interface }}
category_id: iiotg-tsn
_summary: Traffic scheduling on {{ interface }}
depends:
    iiotg-tsn/tsn-detected
imports: from com.canonical.plainbox import manifest
requires:
    manifest.has_iiotg_tsn == 'True'
plugin: shell
user: root
_purpose:
    To check if the system can transmit 4 streams of iperf udp traffic
    using TAPRIO qdisc to limit the bandwidth of each stream.
environ:
    TSN_CREDIT_BASED_SHAPER_TESTING_TIME
command:
    iiotg_tsn.py --run traffic_scheduling --interface {{ interface }} -t "${TSN_CREDIT_BASED_SHAPER_TESTING_TIME:-25}" --server-ip {{ server_ip }}


unit: template
template-resource: iiotg-tsn/tsn-device-ip-match
template-unit: job
template-id: iiotg-tsn/ieee802-1qbu/check-frame-preemption
id: iiotg-tsn/ieee802-1qbu/check-frame-preemption-{interface}
category_id: iiotg-tsn
_summary: Frame preemption check
depends:
    iiotg-tsn/tsn-detected
plugin: shell
user: root
imports:
    from com.canonical.plainbox import manifest
    from com.canonical.certification import snap
requires:
    snap.name == "ethtool-rt"
    manifest.has_iiotg_tsn == 'True'
command:
    echo "## Setting frame preemption on..."
    ethtool-rt.ethtool --set-frame-preemption {interface} fp on
    ret=$?
    if [[ "$ret" -ne 0 ]]; then
        echo "[FAIL] Cannot set frame preemption via the command below"
        echo "ethtool-rt.ethtool --set-frame-preemption {interface} fp on"
        echo ""
        exit 1
    fi
    echo "## Showing frame preemption settings..."
    output=$(ethtool-rt.ethtool --show-frame-preemption {interface})
    echo "$output"
    if ! echo "$output" | grep -q "enabled: enabled"; then
        echo "[FAIL] Frame Preemption is not enabled!"
        echo ""
        exit 1
    fi
    echo "[PASS] Set Frame Preemption successfully!"
