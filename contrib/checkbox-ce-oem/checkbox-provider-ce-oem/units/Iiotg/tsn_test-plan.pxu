id: iiotg-tsn/ieee802-1as-2011
_name: Iiotg Time Sensitive Networking Test Plan for IEEE 802.1AS-2011
_description:
    This testplan is to check if it could follow IEEE 802.1AS-2011.
     - To achieve time synchronization between two platforms.
     - To synchronize each platforms's system clock with PHC (Physical hardware clock)
       using hardware cross-timestamping (which is selected by phc2sys automatically).
unit: test plan
bootstrap_include:
    iiotg-tsn/tsn-device-ip-match
include:
    iiotg-tsn/test-env-setup
    iiotg-tsn/ieee802-1as-2011/ptp4l-interfaces
    iiotg-tsn/ieee802-1as-2011/phc2sys-interfaces

id: iiotg-tsn-ieee802-1qav
_name: Iiotg Time Sensitive Networking Test Plan for IEEE 802.1Qav
_description:
    This testplan is to check if it could follow IEEE 802.1Qav Credit-Based Shaper.
unit: test plan
bootstrap_include:
    iiotg-tsn/tsn-device-ip-match
include:
    iiotg-tsn/test-env-setup
    iiotg-tsn/ieee802-1qav/credit-based-shaper

id: iiotg-tsn-ieee802-1qbv
_name: Iiotg Time Sensitive Networking Test Plan for IEEE 802.1Qbv
_description:
    This testplan is to check if it could follow IEEE 802.1Qbv Time Aware Shaper (TAS).
unit: test plan
bootstrap_include:
    iiotg-tsn/tsn-device-ip-match
include:
    iiotg-tsn/test-env-setup
    iiotg-tsn/ieee802-1qbv/traffic-scheduling

id: iiotg-tsn-ieee802-1qbu
_name: Iiotg Time Sensitive Networking Test Plan for IEEE 802.1Qbu
_description:
    This testplan is to check if it could follow IEEE 802.1Qbu Frame Preemption.
unit: test plan
bootstrap_include:
    iiotg-tsn/tsn-device-ip-match
include:
    iiotg-tsn/test-env-setup
    iiotg-tsn/ieee802-1qbu/check-frame-preemption
