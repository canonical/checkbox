id: jetson-container/cuda-samples-docker-13.0.0-runtime
command:
  # shellcheck disable=SC2002,SC2006,SC2046,SC2086,SC2181
  set -ex
  docker run --rm --net=host --runtime nvidia -e DISPLAY=$DISPLAY \
    -e LD_PRELOAD=/usr/lib/aarch64-linux-gnu/nvidia/libcuda.so \
    -v /tmp/.X11-unix/:/tmp/.X11-unix -v \
    /opt/nvidia/cuda-samples/:/opt/nvidia/cuda-samples -v \
    /opt/nvidia/run-cuda-samples.py:/opt/nvidia/run-cuda-samples.py \
    nvcr.io/nvidia/cuda:13.0.0-runtime-ubuntu24.04 \
    bash -c "apt update && apt install -y python3 && /opt/nvidia/run-cuda-samples.py -c 1_Utilities"
plugin: shell
category_id: jetson-container
flags: also-after-suspend
estimated_duration: 10m
user: root
imports:
 from com.canonical.certification import package
 from com.canonical.plainbox import manifest
requires:
 package.name == 'cuda-toolkit-13-0'
 package.name == 'nvidia-container-toolkit'
 manifest.is_Jetson == 'True'

