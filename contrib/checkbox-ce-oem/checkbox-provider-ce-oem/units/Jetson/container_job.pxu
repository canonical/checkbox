    /usr/src/tensorrt/:/usr/src/tensorrt/ \
    nvcr.io/nvidia/l4t-tensorrt:r10.3.0-runtime \
    /opt/nvidia/run-tensorrt-samples.py
plugin: shell
category_id: jetson-container
flags: also-after-suspend
