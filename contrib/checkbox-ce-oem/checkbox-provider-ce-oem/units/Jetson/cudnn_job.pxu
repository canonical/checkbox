id: jetson-gpu/cudnn/mnistCUDNN
category_id: jetson-gpu
flags: also-after-suspend
user: root
plugin: shell
imports: from com.canonical.certification import package
 from com.canonical.plainbox import manifest
requires:
 package.name == 'libcudnn9-samples'
 package.name == 'libfreeimage-dev'
 manifest.is_Jetson == 'True'
command:
  cd /usr/src/cudnn_samples_v9/mnistCUDNN/ || exit
  ./mnistCUDNN
_summary:
 Run the mnistCUDNN sample
_description:
 Run the mnistCUDNN sample

