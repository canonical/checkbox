id: jetson-core-gpu/cudnn/conv
category_id: jetson-core-gpu
flags: also-after-suspend
user: root
plugin: shell
imports: from com.canonical.certification import executable
 from com.canonical.plainbox import manifest
requires:
 executable.name == 'cudnn-samples.conv-sample'
 manifest.is_Jetson == 'True'
command: sudo cudnn-samples.conv-sample
_summary:
 Run the cudnn-samples.conv-sample on core
_description:
 Run the cudnn-samples.conv-sample on core

