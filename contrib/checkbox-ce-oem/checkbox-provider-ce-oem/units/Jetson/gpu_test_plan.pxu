id: jetson-gpu-automated
unit: test plan
_name: Jetson GPU automated tests
_description: Automated Jetson GPU tests
include:
    jetson-gpu/nvidia-smi
    jetson-core-gpu/nvidia-smi

id: jetson-cuda-automated
unit: test plan
_name: Jetson CUDA automated tests
_description: Automated Jetson CUDA tests
include:
    jetson-gpu/cuda-samples-name
    jetson-core-gpu/cuda-samples-name
bootstrap_include:
    jetson_cuda_samples_list
    jetson_cuda_samples_list_core

id: jetson-tensorrt-automated
unit: test plan
_name: Jetson TensorRT automated tests
_description: Automated Jetson TensorRT tests
include:
    jetson-gpu/tensorrt-samples-name
    jetson-core-gpu/tensorrt-samples-name
bootstrap_include:
    jetson_tensorrt_samples_list
    jetson_tensorrt_samples_list_core

id: jetson-cudnn-automated
unit: test plan
_name: Jetson cuDNN automated tests
_description: Automated Jetson cuDNN tests
include:
    jetson-gpu/cudnn/mnistCUDNN
    jetson-gpu/cudnn/conv_sample
    jetson-core-gpu/cudnn/conv
    jetson-core-gpu/cudnn/mnist-cudnn
    jetson-core-gpu/cudnn/multi-head-attention
    jetson-core-gpu/cudnn/rnn
