unit: template
template-resource: jetson_nvpmodel_list
template-unit: job
id: jetson-nvpmodel/get_mode_{mode_id}
category_id: jetson-nvpmodel
user: root
plugin: shell
imports: from com.canonical.certification import executable
 from com.canonical.plainbox import manifest
requires:
 executable.name == 'nvpmodel'
 executable.name == 'jetson_clocks'
 manifest.is_Jetson == 'True'
command:
  echo "checking the mode={mode_id}"
  sudo nvpmodel --query
  sudo jetson_clocks --show
  power_mode=$(sudo nvpmodel --query | tr -s " " | cut -d " " -f4 | head -n 1)
  sudo nvpmodel --parse --verbose | grep POWER_MODEL | grep "$power_mode" | grep ID={mode_id}
_template-summary:
 Confirm that a power mode was correctly set by nvpmodel
_summary:
 Confirm that the power mode ID={mode_id} was correctly set by nvpmodel
_description:
 Confirm that the power mode ID={mode_id} was correctly set by nvpmodel
depends:
  jetson-nvpmodel/set_mode_{mode_id}
