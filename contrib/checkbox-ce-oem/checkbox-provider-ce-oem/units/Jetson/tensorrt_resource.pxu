id: jetson_tensorrt_samples_list
estimated_duration: 0.01
plugin: resource
imports: from com.canonical.plainbox import manifest
requires: manifest.is_Jetson == 'True'
command:
    /opt/nvidia/run-tensorrt-samples.py --list
_description: Creates resource info for Tensor RT samples tests

id: jetson_tensorrt_samples_list_core
estimated_duration: 0.01
plugin: resource
imports: from com.canonical.plainbox import manifest
requires: manifest.is_Jetson == 'True'
command:
    for f in $(cat /snap/tensorrt-samples/current/etc/tensorrt-samples.list); do printf "name: %s\n\n" "$f"; done
_description: Creates resource info for Tensor RT samples tests
