id: jetson-core-vpi/run-sample-snap-cpu
_summary: Run VPI samples (snap) on CPU
plugin: shell
category_id: jetson-core-vpi
imports:
 from com.canonical.certification import snap
 from com.canonical.plainbox import manifest
requires:
 snap.name == 'vpi-samples'
 manifest.is_Jetson == 'True'
user: root
command:
  set -ex
  cd /tmp
  snap run vpi-samples.vpi-sample-01-convolve-2d cpu  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/kodim08.png
  snap run vpi-samples.vpi-sample-03-harris-corners cpu  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/kodim08.png
  snap run vpi-samples.vpi-sample-06-klt-tracker cpu  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/dashcam.mp4 /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/dashcam_bboxes.txt
  snap run vpi-samples.vpi-sample-10-perspwarp cpu  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/noisy.mp4
  snap run vpi-samples.vpi-sample-14-background-subtractor cpu  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/pedestrians.mp4

