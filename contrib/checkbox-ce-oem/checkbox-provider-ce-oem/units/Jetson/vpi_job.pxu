unit: category
id: jetson-vpi
_name: Jetson VPI tests

unit: category
id: jetson-core-vpi
_name: Jetson core VPI tests

id: jetson-vpi/install-packages
_summary: Install VPI packages
plugin: shell
category_id: jetson-vpi
imports:
 from com.canonical.contrib import jetson_tegra_details
 from com.canonical.plainbox import manifest
requires:
 jetson_tegra_details.model != 'NVIDIA IGX Orin Development Kit'
 manifest.is_Jetson == 'True'
user: root
command:
  if [ $(lsb_release --codename | cut -f2) == "noble" ]; then
    apt install -y vpi4-dev vpi4-samples
  elif [ $(lsb_release --codename | cut -f2) == "jammy" ]; then
    apt install -y vpi3-dev vpi3-samples
    update-alternatives \
          --install /etc/ld.so.conf.d/aarch64-linux-gnu_EGL.conf \
          aarch64-linux-gnu_egl_conf \
          /usr/lib/aarch64-linux-gnu/tegra-egl/ld.so.conf 1000
  fi
  ldconfig
  apt install -y nvidia-vpi libopencv-dev libopencv cmake build-essential python3-numpy python3-pil libopencv-python


id: jetson-vpi/build-sample
_summary: Build VPI sample code
plugin: shell
category_id: jetson-vpi
depends: jetson-vpi/install-packages
imports:
 from com.canonical.contrib import jetson_tegra_details
 from com.canonical.plainbox import manifest
requires:
 jetson_tegra_details.model != 'NVIDIA IGX Orin Development Kit'
 manifest.is_Jetson == 'True'
user: root
command:
  set -ex
  unset LD_LIBRARY_PATH
  export
  cd /opt/nvidia/vpi*/samples/
  for f in */CMakeLists.txt ; do pushd $(dirname $f) ; cmake -DOpenCV_DIR=/usr/lib/cmake/opencv4 . ; VERBOSE=1 make -j 2 ; popd ; done

id: jetson-vpi/run-sample-cpp-cpu
_summary: Run VPI samples (C++) on CPU
plugin: shell
category_id: jetson-vpi
depends: jetson-vpi/build-sample
user: root
imports: from com.canonical.plainbox import manifest
requires: manifest.is_Jetson == 'True'
command:
  set -ex
  cd /opt/nvidia/vpi*/samples/
  pushd 01-convolve_2d
  ./vpi_sample_01_convolve_2d cpu  ../assets/kodim08.png
  popd
  pushd 03-harris_corners
  ./vpi_sample_03_harris_corners cpu  ../assets/kodim08.png
  popd
  pushd 06-klt_tracker
  ./vpi_sample_06_klt_tracker cpu  ../assets/dashcam.mp4 ../assets/dashcam_bboxes.txt
  popd
  pushd 10-perspwarp
  ./vpi_sample_10_perspwarp cpu  ../assets/noisy.mp4
  popd
  pushd 14-background_subtractor
  ./vpi_sample_14_background_subtractor cpu  ../assets/pedestrians.mp4
  popd

