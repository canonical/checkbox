id: jetson-vpi/run-sample-cpp-pva
_summary: Run VPI samples (C++) on PVA and VIC
plugin: shell
category_id: jetson-vpi
depends: jetson-vpi/build-sample
imports:
 from com.canonical.contrib import jetson_tegra_details
 from com.canonical.plainbox import manifest
requires:
 jetson_tegra_details.model != 'NVIDIA Jetson Orin Nano Developer Kit' and jetson_tegra_details.model != 'NVIDIA Jetson Orin Nano Engineering Reference Developer Kit Super'
 manifest.is_Jetson == 'True'
user: root
command:
  set -ex
  cd /opt/nvidia/vpi*/samples/
  pushd 01-convolve_2d
  ./vpi_sample_01_convolve_2d pva  ../assets/kodim08.png
  popd
  pushd 02-stereo_disparity
  ./vpi_sample_02_stereo_disparity ofa          ../assets/chair_stereo_left.png ../assets/chair_stereo_right.png
  ./vpi_sample_02_stereo_disparity ofa-pva-vic  ../assets/chair_stereo_left.png ../assets/chair_stereo_right.png
  popd
  pushd 03-harris_corners
  ./vpi_sample_03_harris_corners pva  ../assets/kodim08.png
  popd
  pushd 06-klt_tracker
  ./vpi_sample_06_klt_tracker pva  ../assets/dashcam.mp4 ../assets/dashcam_bboxes.txt
  popd
  pushd 09-tnr
  ./vpi_sample_09_tnr vic  ../assets/noisy.mp4
  popd
  pushd 10-perspwarp
  ./vpi_sample_10_perspwarp vic  ../assets/noisy.mp4
  popd


id: jetson-vpi/run-sample-py-cpu
_summary: Run VPI samples (Python) on CPU
plugin: shell
category_id: jetson-vpi
depends: jetson-vpi/install-packages
user: root
imports: from com.canonical.plainbox import manifest
requires: manifest.is_Jetson == 'True'
command:
  set -ex
  unset PYTHONUSERBASE
  unset PYTHONPATH
  unset PYTHONHOME
  cd /opt/nvidia/vpi*/samples/
  pushd 01-convolve_2d
  /usr/bin/python3 main.py cpu  ../assets/kodim08.png
  popd
  pushd 03-harris_corners
  /usr/bin/python3 main.py cpu  ../assets/kodim08.png
  popd
  pushd 06-klt_tracker
  /usr/bin/python3 main.py cpu  ../assets/dashcam.mp4 ../assets/dashcam_bboxes.txt
  popd
  pushd 10-perspwarp
  /usr/bin/python3 main.py cpu  ../assets/noisy.mp4
  popd
  pushd 14-background_subtractor
  /usr/bin/python3 main.py cpu  ../assets/pedestrians.mp4
  popd

