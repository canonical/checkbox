id: jetson-core-vpi/run-sample-snap-pva
_summary: Run VPI samples (snap) on PVA and VIC
plugin: shell
category_id: jetson-core-vpi
imports:
 from com.canonical.contrib import jetson_tegra_details
 from com.canonical.certification import snap
 from com.canonical.plainbox import manifest
 from com.canonical.contrib import jetson_lockdown
requires:
 snap.name == 'vpi-samples'
 jetson_tegra_details.model != 'NVIDIA Jetson Orin Nano Developer Kit' and jetson_tegra_details.model != 'NVIDIA Jetson Orin Nano Engineering Reference Developer Kit Super'
 jetson_lockdown.mode == 'none'
 manifest.is_Jetson == 'True'
user: root
command:
  set -ex
  AUTH_VAL=$(cat /sys/kernel/debug/pva0/vpu_app_authentication)
  trap "echo $AUTH_VAL > /sys/kernel/debug/pva0/vpu_app_authentication" EXIT
  cd /tmp
  echo 0 > /sys/kernel/debug/pva0/vpu_app_authentication
  snap run vpi-samples.vpi-sample-01-convolve-2d pva  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/kodim08.png
  snap run vpi-samples.vpi-sample-02-stereo-disparity ofa          /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/chair_stereo_left.png /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/chair_stereo_right.png
  snap run vpi-samples.vpi-sample-02-stereo-disparity ofa-pva-vic  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/chair_stereo_left.png /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/chair_stereo_right.png
  snap run vpi-samples.vpi-sample-03-harris-corners pva  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/kodim08.png
  snap run vpi-samples.vpi-sample-06-klt-tracker pva  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/dashcam.mp4 /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/dashcam_bboxes.txt
  snap run vpi-samples.vpi-sample-09-tnr vic  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/noisy.mp4
  snap run vpi-samples.vpi-sample-10-perspwarp vic  /snap/vpi-samples/current/opt/nvidia/vpi3/samples/assets/noisy.mp4
