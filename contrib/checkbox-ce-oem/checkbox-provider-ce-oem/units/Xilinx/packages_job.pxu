unit: category
id: xilinx-package-tests
_name: Xilinx Package Functionality Tests

id: xilinx-package-test/dfx-mgr-with-no-args
category_id: xilinx-package-tests
plugin: shell
_summary: DFX Manager Package - Call With No Args
imports:
 from com.canonical.certification import package
 from com.canonical.plainbox import manifest
requires:
 package.name == 'dfx-mgr'
 manifest.is_Xilinx == 'True'
user: root
estimated_duration: 1s
command:
  version_under_test=$(apt-cache policy dfx-mgr | awk '/Installed:/ {print $2}')
  xilinx_dfx_mgr_test.py -v --vut $version_under_test TestDfxMgrPackage.test_call_with_no_args


