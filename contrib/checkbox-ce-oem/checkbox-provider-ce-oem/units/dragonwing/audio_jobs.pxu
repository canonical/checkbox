plugin: user-interact-verify
category_id: dragonwing-audio
flags: also-after-suspend
id: dragonwing-audio/record-16-bit-48000Hz-stereo
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.has_audio_capture == "True"
    manifest.has_audio_playback == "True"
    manifest.is_dragonwing_series == 'True'
    manifest.has_audio_codec_support == 'True'
depends: dragonwing-audio/check-pulseaudio-running
_summary: Audio record 16 bit stereo 48000Hz 
_description: The test will record sound for 10 seconds and playback right after
_steps:
    Press enter to start record for 10 seconds
command:
    echo "Start recording..."
    arecord -d 10 -r 48000 --format=S16_LE -c 2 -t wav mic_recording.wav
    echo "Recording done"
    echo "Playing the recorded sound clip..."
    aplay -c 2 -r 48000 -f S16_LE mic_recording.wav
    rm mic_recording.wav
_verification:
    1. Is the clip sounded no pops and glitches?
    2. the mediainfo of the clip's sample rate, bitrate, and channels should be matched

plugin: manual
category_id: dragonwing-audio
flags: also-after-suspend
id: dragonwing-audio/playback-16-bit-44100Hz-mono
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.has_audio_playback == "True"
    manifest.is_dragonwing_series == 'True'
    manifest.has_audio_codec_support == 'True'
depends: dragonwing-audio/check-pulseaudio-running
_summary: Audio playback 16 bit 44100Hz mono sound clip 
_description: the test aim to check the sound clip playback 
_steps:
    1. Prepare a 16 bit 44100Hz mono sound clip
    2. play the file with command
    $ aplay -c 1 -r 44100 -f S16_LE {audio_file}
_verification:
    Is the clip sounded no pops and glitches?

plugin: shell
category_id: dragonwing-audio
flags: also-after-suspend
id: dragonwing-audio/check-pulseaudio-running
imports: from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_audio_codec_support == 'True'
_summary: Check if pulseaudio is running
command:
    pgrep -ax pulseaudio

plugin: shell
category_id: dragonwing-audio
flags: also-after-suspend
id: dragonwing-audio/check-diag-router-running
imports: from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_audio_codec_support == 'True'
_summary: Check if diag-router is running
command:
    pgrep -ax diag-router

plugin: shell
category_id: dragonwing-audio
flags: also-after-suspend
id: dragonwing-audio/check-acdb-files-exist
imports: from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_audio_codec_support == 'True'
_summary: Check if acdb files exist
command:
    file_found=$(find / -name workspaceFileXml.qwsp 2>/dev/null)
    if [[ -z "$file_found" ]]; then
        echo "workspaceFileXml.qwsp not found"
        exit 1
    else
        echo "File found:"
        echo "$file_found"
    fi

plugin: manual
category_id: dragonwing-audio
flags: also-after-suspend
id: dragonwing-audio/decode-offload-CBR-stereo-mp3
imports: from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_audio_codec_support == 'True'
_summary: Audio decode offload with CBR stereo mp3 file
_description: Test decode offload with CBR stereo mp3 audio clip
_steps:
    1. Prepare an CBR stereo mp3 audio clip
    2. Playback the clip on DUT by
    $ paplay -v -d offload0 --encoding=mpeg --raw {audio_file}
_verification:
    sound has no crashes or obvious distortions

