plugin: user-interact-verify
category_id: dragonwing-audio
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-launch-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_hardware_audio_codec_support == 'True'
id: dragonwing-audio/encode-16bit-8000Hz-mono-wav
_summary: encode 16bit 8000Hz mono wav audio clip
environ: GST_TEST_DATA PLAINBOX_SESSION_SHARE
_steps:
    Press enter to start playing the audio clip
_verification:
    Recorded file should have correct property and sound without glitches, pops, pause
command: 
    set -x
    export GST_DEBUG=2
    mkdir -p "$PLAINBOX_SESSION_SHARE/audio"
    timeout -s2 --preserve-status 5s gst-launch-1.0 -f -v pulsesrc ! audio/x-raw, format=S16LE, channels=1, rate=8000 ! audioconvert ! wavenc ! filesink location="$PLAINBOX_SESSION_SHARE/audio/encode-16bit-8000Hz-mono.wav"

