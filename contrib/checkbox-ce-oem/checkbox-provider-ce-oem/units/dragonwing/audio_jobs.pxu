plugin: manual
category_id: dragonwing-audio
flags: also-after-suspend
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-play-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_hardware_audio_codec_support == 'True'
id: dragonwing-audio/gst-play-trickmode
_summary: Verify gst-play trickmode 
_description:
    Verified gst-play-1.0 trickmode control
_steps:
    1. excute command to play audio clip
      $ gst-play-1.0 trickmode_1.wav --audiosink='pulsesink'
    2. While playing, 
      - press space to pause
      - press 0 to restart
_verification:
    Does it pause while pressing space?
    Does it restart while pressing 0?

plugin: manual
category_id: dragonwing-audio
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-play-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_hardware_audio_codec_support == 'True'
id: dragonwing-audio/gst-play-trickmode-multifiles
_summary: Verify trickmode switch between multifiles
_description:
    Verified gst-play-1.0 trickmode control
_steps:
    1. excute command to play audio clip
      $ gst-play-1.0 trickmode_1.wav trickmode_2.wav --audiosink='pulsesink'
    2. While playing, press > or < to switch between two clips
_verification:
    Does it switch between clips?

plugin: manual
category_id: dragonwing-audio
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-play-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_hardware_audio_codec_support == 'True'
id: dragonwing-audio/gst-play-trickmode-volume
_summary: Verify gst-play trickmode adjust volume
_description:
    Verified gst-play-1.0 trickmode control
_steps:
    1. excute command to play audio clip by half volume
      $ gst-play-1.0 trickmode_1.wav trickmode_1.wav --audiosink='pulsesink' --volume=0.5
    2. excute command to play audio clip by 0 volume
      $ gst-play-1.0 trickmode_1.wav trickmode_1.wav --audiosink='pulsesink' --volume=0.0
    3. excute command to play audio clip by full volume
      $ gst-play-1.0 trickmode_1.wav trickmode_1.wav --audiosink='pulsesink' --volume=1.0
_verification:
    Does the volume changes? 

plugin: user-interact-verify
category_id: dragonwing-audio
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-launch-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_hardware_audio_codec_support == 'True'
id: dragonwing-audio/decode-16bit-8000hz-mono-wav
_summary: decode 16bit 8000hz mono wav audio clip
environ: GST_TEST_DATA
_steps:
    Press enter to start playing the audio clip
_verification:
    Playback should be smooth without glitches, pops, pause
command: 
    set -x
    export GST_DEBUG=2
    timeout -s2 --preserve-status 5s gst-launch-1.0 -f filesrc location="$GST_TEST_DATA/audio/decode-16bit-8000hz-mono.wav" ! wavparse ! audioconvert ! pulsesink

