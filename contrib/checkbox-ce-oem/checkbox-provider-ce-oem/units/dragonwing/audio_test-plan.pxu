id: dragonwing-audio-full
unit: test plan
_name: Dragonwing audio tests
_description: Full audio tests for dragonwing
include:
nested_part:
    dragonwing-audio-manual
    dragonwing-audio-automated

id: dragonwing-audio-manual
unit: test plan
_name: Dragonwing manual audio tests
_description: Manual audio tests for dragonwing
include:
    dragonwing-audio/record-16-bit-48000Hz-stereo
    dragonwing-audio/playback-16-bit-44100Hz-mono
    dragonwing-audio/decode-offload-CBR-stereo-mp3
    dragonwing-audio/decode-offload-VBR-mono-mp3
nested_part:
    dragonwing-audio-gstreamer-manual

id: dragonwing-audio-automated
unit: test plan
_name: Dragonwing automated audio tests
_description: Automated audio tests for dragonwing
include:
    dragonwing-audio/check-pulseaudio-running
    dragonwing-audio/check-diag-router-running
    dragonwing-audio/check-acdb-files-exist

