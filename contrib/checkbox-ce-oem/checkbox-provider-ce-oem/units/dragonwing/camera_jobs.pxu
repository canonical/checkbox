plugin: manual
category_id: dragonwing-camera
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-launch-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_vendor_specific_mipi_camera == 'True'
id: dragonwing-camera/multi-streams
flags: also-after-suspend
_summary: Test multi-streams pipeline and checsk output files
_purpose:
    Test multi-streams pipeline and check output files
_steps:
    1. Test the below command with maximum supported resolution of connected camera
    2. Test the below command with minimun supported resolution of connected camera
    gst-launch-1.0 -f -e qtiqmmfsrc name=camsrc camera={camera} video_2::type=preview \
    camsrc.video_0 ! video/x-raw,format=NV12_Q08C,width={width},height={height},framerate=30/1,interlace-mode=progressive,colorimetry=bt601 ! queue \
    ! v4l2h264enc capture-io-mode=4 output-io-mode=5 extra-controls="controls,video_bitrate_mode=0,video_bitrate=6000000,h264_i_frame_qp_value=27,h264_b_frame_qp_value=28,h264_p_frame_qp_value=28,video_gop_size=29,h264_entropy_mode=1,h264_profile=4;" ! queue \
    ! h264parse ! mp4mux ! queue ! filesink location="multi-streams.mp4" \
    camsrc.video_1 ! "image/jpeg,width={width},height={height}" ! queue ! multifilesink location=multi-streams_%d.jpg max-files=1 sync=true async=false \
    camsrc.video_2 ! "video/x-bayer,format=rggb,bpp=(string)10,width=4056,height=3040" ! multifilesink location=multi-streams_%d.raw max-files=1 sync=true async=false
_verification:
    check the output files, no abnormal symptoms are observed

plugin: manual
category_id: dragonwing-camera
imports:
    from com.canonical.certification import executable
    from com.canonical.plainbox import manifest
requires:
    executable.name == 'gst-launch-1.0'
    manifest.is_dragonwing_series == 'True'
    manifest.has_vendor_specific_mipi_camera == 'True'
id: dragonwing-camera/multi-cameras
flags: also-after-suspend
_summary: Test multi camera encoding
_purpose:
    Check multi cameras encoding to .mp4 file
_steps:
    1. Prepare two supported camera sensors and connect to the system
    2. Test the below command with maximum supported resolution of both cameras
    3. Test the below command with minimun supported resolution of both cameras
    gst-launch-1.0 -f -e qtiqmmfsrc name=camsrc \
    ! video/x-raw,format=NV12_Q08C,width={width},height={height},framerate=30/1,interlace-mode=progressive,colorimetry=bt601 \
    ! v4l2h264enc capture-io-mode=4 output-io-mode=5 ! h264parse ! mp4mux \
    ! filesink location=camera1.mp4 \
    qtiqmmfsrc camera=1 ! video/x-raw,format=NV12_Q08C,width={width},height={height},framerate=30/1,interlace-mode=progressive,colorimetry=bt601 \
    ! v4l2h264enc capture-io-mode=4 output-io-mode=5 ! h264parse ! mp4mux \
    ! filesink location=camera2.mp4
_verification:
    check the output camera.mp4, no abnormal symptoms are observed
