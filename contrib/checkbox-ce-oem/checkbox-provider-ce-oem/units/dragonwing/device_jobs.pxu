id: dragonwing_soc_info
plugin: resource
_summary: Collect and report the type of SoC
estimated_duration: 0.1
environ: DRAGONWING_SOC
command:
    echo "SoC: $DRAGONWING_SOC"
    echo

id: dragonwing_platform_info
plugin: resource
_summary: Report the model type of platform
estimated_duration: 0.1
environ: DRAGONWING_PLATFORM
command:
    echo "Model: $DRAGONWING_PLATFORM"
    echo
