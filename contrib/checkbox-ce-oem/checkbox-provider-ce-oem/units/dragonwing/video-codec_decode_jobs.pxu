plugin: shell
category_id: dragonwing-video
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_video_codec == 'True'
id: dragonwing-video/decoder-h264-480p-automated
flags: also-after-suspend
_summary: Test video decoder H264 480p to fakesink
environ: PLAINBOX_SESSION_SHARE
command:
    set -x
    export GST_DEBUG=2
    export GST_PLUGIN_PATH=/usr/lib/aarch64-linux-gnu/gstreamer-1.0/
    mkdir -p "$PLAINBOX_SESSION_SHARE/video"
    timeout -s2 --preserve-status 10s gst-launch-1.0 -f -v filesrc location="$GST_TEST_DATA/video/480p_30fps_h264.mp4" \
    ! qtdemux ! h264parse ! v4l2h264dec capture-io-mode=4 output-io-mode=4 \
    ! video/x-raw, format=NV12 ! fakesink sync=true

