plugin: manual
category_id: dragonwing-video
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_video_codec == 'True'
id: dragonwing-video/decoder-h264
flags: also-after-suspend
_summary: Test video decoder pipeline and check the output on actual display
_purpose: Test video decoder pipeline and check the output on actual display
_steps:
    1. Test the below command with maximum/minimum supported resolutions
    gst-launch-1.0 -f -v filesrc location="$GST_TEST_DATA/video/{resolution}_30fps_h264.mp4" \
    ! qtdemux ! h264parse ! v4l2h264dec capture-io-mode=4 output-io-mode=4 \
    ! video/x-raw, format=NV12 ! waylandsink fullscreen=true
_verification:
    check the decode output on connected display, no abnormal symptoms are observed

