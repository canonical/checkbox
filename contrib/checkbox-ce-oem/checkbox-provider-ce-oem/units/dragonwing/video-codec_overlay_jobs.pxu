plugin: shell
category_id: dragonwing-video
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_video_codec == 'True'
id: dragonwing-video/overlay-static-image-automated
flags: also-after-suspend
_summary: Test video overlay - static image
environ: PLAINBOX_SESSION_SHARE
command:
    set -x
    setprop persist.overlay.use_c2d_blit 2
    export GST_DEBUG=2
    export GST_PLUGIN_PATH=/usr/lib/aarch64-linux-gnu/gstreamer-1.0/
    mkdir -p "$PLAINBOX_SESSION_SHARE/video"
    timeout -s2 --preserve-status 10s gst-launch-1.0 -f -v filesrc location="$GST_TEST_DATA/video/1080p_30fps_h264.mp4" \
    ! qtdemux ! queue ! h264parse ! v4l2h264dec capture-io-mode=4 output-io-mode=4 ! video/x-raw, format=NV12 \
    ! qtivoverlay images="{(structure)\"Image1,path=$GST_TEST_DATA/video/static_image.rgba,resolution=<240,56>,destination=<0,0,240,56>;\"}" \
    ! v4l2h264enc capture-io-mode=4 output-io-mode=5 extra-controls="controls,video_bitrate=5000000,video_bitrate_mode=0;" \
    ! queue ! h264parse ! mp4mux ! queue \
    ! filesink location="$PLAINBOX_SESSION_SHARE/video/overlay-static-image-automated.mp4"

