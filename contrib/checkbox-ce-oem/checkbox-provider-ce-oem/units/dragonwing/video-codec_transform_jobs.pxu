plugin: manual
category_id: dragonwing-video
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_video_codec == 'True'
id: dragonwing-video/transform-scale
flags: also-after-suspend
_summary: Test video scale pipeline and check the output video clips
_purpose: Test video scale pipeline and check the output video clips
_steps:
    1. Test the below command with scale resolutions
    gst-launch-1.0 -f -v filesrc location="$GST_TEST_DATA/video/{before_resolution}_30fps_h264.mp4" \
    ! qtdemux ! queue ! h264parse ! v4l2h264dec capture-io-mode=4 output-io-mode=4 ! video/x-raw, format=NV12 \
    ! qtivtransform ! queue ! video/x-raw,format=NV12_Q08C,width={after-width},height={after-height},framerate=30/1,interlace-mode=progressive,colorimetry=bt601 \
    ! queue ! v4l2h264enc capture-io-mode=4 output-io-mode=5 ! h264parse ! queue \
    ! mp4mux ! queue ! filesink location=transform-scale.mp4
_verification:
    check the output transform-scale.mp4, no abnormal symptoms are observed