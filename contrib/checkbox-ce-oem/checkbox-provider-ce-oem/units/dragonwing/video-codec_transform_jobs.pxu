plugin: manual
category_id: dragonwing-video
imports:
    from com.canonical.plainbox import manifest
requires:
    manifest.is_dragonwing_series == 'True'
    manifest.has_video_codec == 'True'
id: dragonwing-video/transform-rotate
flags: also-after-suspend
_summary: Test video rotate pipeline and check the output video clips
_purpose: Test video rotate pipeline and check the output video clips
_steps:
    1. Test the below command with rotate=90CW/180/90CCW
    gst-launch-1.0 -f -v filesrc location="$GST_TEST_DATA/video/1080p_30fps_h264.mp4" \
    ! qtdemux ! queue ! h264parse ! v4l2h264dec capture-io-mode=4 output-io-mode=4 ! video/x-raw, format=NV12 \
    ! qtivtransform rotate={rotate_degree} ! queue ! video/x-raw,format=NV12_Q08C,width=1920,height=1080,framerate=30/1,interlace-mode=progressive,colorimetry=bt601 \
    ! queue ! v4l2h264enc capture-io-mode=4 output-io-mode=5 ! h264parse ! queue \
    ! mp4mux ! queue ! filesink location=transform-rotate.mp4
_verification:
    check the output transform-rotate.mp4, no abnormal symptoms are observed

