name: checkbox-oem
summary: Checkbox OEM public providers
description: |
  Checkbox OEM public providers
version: $SNAP_VERSION
grade: stable
confinement: strict
base: $SNAPBASE

slots:
  custom-frontend:
    interface: content
    content: custom-frontend
    read:
      - /

package-repositories:
  - type: apt
    ppa: checkbox-dev/stable # used to pull the installation machinery

parts:
  checkbox-provider-oem:
    plugin: dump
    source: .
    source-type: local
    build-environment:
      - PYTHONPYCACHEPREFIX: "/tmp"
    build-packages:
      - checkbox-ng
      - intltool
      - gcc
      - make
      - flake8
      - bats
      - shellcheck
      - python3
      - python3-jinja2
      - python3-packaging
    stage-packages:
      - bzip2
      - curl
      - git
      - iputils-ping
      - i2c-tools
      - jq
      - libopenscap25t64
      - lsb-release
      - modemmanager
      - msr-tools
      - openscap-scanner
      - pciutils
      - python3
      - python3-apt
      - python3-pip
      - smbios-utils
      - ubuntu-report
      - xautomation
      - wget
    override-build: |
      python3 manage.py build
      python3 manage.py install --layout=relocatable --prefix=/providers/oem --root="$CRAFT_PART_INSTALL"
  extra-path-environment:
    plugin: nil
    override-build: |
      echo "LD_LIBRARY_PATH+=/usr/lib/$CRAFT_ARCH_TRIPLET_BUILD_FOR/
      " >> $CRAFT_PART_INSTALL/extra_path_environment
    stage:
      - extra_path_environment
