#!/bin/bash

if [ -n "$SNAP" ]; then
    DPKG_STATUS="/var/lib/snapd/hostfs/var/lib/dpkg/status";
else
    DPKG_STATUS="/var/lib/dpkg/status";
fi

failed()
{
    >&2 echo "$*"
    >&2 echo "$0 failed!"
    exit 1
}

passed()
{
    echo "$*"
    echo "$0 passed!"
    exit 0
}

is_installed() {
    local pkg=$1
    # Use awk to treat the file as blocks separated by blank lines
    awk -v pkg="$pkg" '
        BEGIN { RS=""; FS="\n" }
        $1 == "Package: "pkg {
            if ($0 ~ /Status: install ok installed/) { exit 0 } else { exit 1 }
        }
    ' "$DPKG_STATUS"
}

# Check userguide package if installed in sutton project
# https://warthogs.atlassian.net/browse/OEX86-301
check_sutton_userguide() {
    # userguide package will depend on a oem-sutton-common-doc package
    local packages=$(grep "^Package: oem-sutton-.*-doc$" "$DPKG_STATUS" | cut -d' ' -f2)
    for pkg in $packages; do
        platform_name=$(echo "${pkg}" | cut -d'-' -f3)
        if [ "$platform_name" = "common" ]; then
            # Ignore common doc package
            continue
        fi

        if is_installed "${pkg}"; then
            passed "Found the platform userguide package: ${pkg}"
        fi
    done
    # No platform userguide package found, then fail the test
    failed "Missing platform userguide packages!!!"
}

main() {
    check_sutton_userguide
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    main "$@"
fi
