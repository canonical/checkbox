  oem-cpu-automated
  oem-crypto-automated
  oem-device-automated
  oem-digital-io-automated
  oem-eeprom-automated
  oem-ethernet-automated
  oem-fan-automated
  oem-gadget-automated
  oem-gpio-automated
  oem-gps-automated
  oem-graphics-automated
  oem-iio-sensors-automated
  oem-installation-info-automated
  oem-kernel-automated
  oem-led-automated
  oem-mir-automated
  oem-miscellanea-automated
  oem-mtd-automated
  oem-optee-automated
  oem-otg-automated
  oem-power-management-automated
  oem-printer-automated
  oem-ptp-automated
  oem-regulator-automated
  oem-rpmsg-automated
  oem-rtc-automated
  oem-serial-automated
  oem-socketcan-stress-automated
  oem-spi-automated
  oem-strict-confinement-automated
  oem-thermal-automated
  oem-touchpad-automated
  oem-video-codec-automated
  oem-vpu-automated
  oem-wifi-automated
  oem-wwan-automated
certification_status_overrides:
  apply blocker to .*

id: oem-manual
unit: test plan
_name: OEM - Manual only OEM tests for Ubuntu Core and Classic
_description:
  Ubuntu Core and Classic OEM test plan for the hardware. This test plan contains
  all of the tests that require manual control of device hardware
  or some other user input to complete.
estimated_duration: 3600
include:
nested_part:
