id: npu-full
unit: test plan
_name: NPU driver tests
include:
    kmd/.*
    umd/.*
bootstrap_include:
    com.canonical.certification::npu_gtest_resource

id: npu-only-known-failures
unit: test plan
_name: NPU driver tests (ONLY known failures)
include:
    known-failure/umd/.*
bootstrap_include:
    com.canonical.certification::npu_gtest_resource

id: npu-with-known-failures
unit: test plan
_name: NPU driver tests (including known failures)
nested_part:
    com.canonical.certification::npu-full
    com.canonical.certification::npu-only-known-failures
