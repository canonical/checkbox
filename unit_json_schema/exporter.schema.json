{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/canonical/checkbox/blob/main/schema_checkbox/exporter.schema.json",
  "title": "Exporter Unit",
  "description": "Schema that describes a Checkbox Exporter unit",
  "type": "object",
  "properties": {
    "unit": {
      "description": "The type of unit.",
      "const": "exporter"
    },
    "id": {
      "description": "Unique identifier of the exporter.",
      "type": "string"
    },
    "summary": {
      "description": "Human-readable name for the exporter.",
      "type": "string"
    },
    "entry_point": {
      "description": "Entry point from the plainbox.exporters namespace.",
      "type": "string",
      "enum": ["jinja2", "text", "xlsx", "json", "rfc822", "tar"]
    },
    "file_extension": {
      "description": "Filename extension to use when the exporter stream is saved to a file.",
      "type": "string"
    },
    "options": {
      "description": "List of options for the exporter entry point.",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "with-io-log",
          "squash-io-log",
          "flatten-io-log",
          "with-run-list",
          "with-job-list",
          "with-resource-map",
          "with-job-defs",
          "with-attachments",
          "with-comments",
          "with-job-via",
          "with-job-hash",
          "with-category-map",
          "with-certification-status",
          "machine-json",
          "with-sys-info",
          "with-summary",
          "with-job-description",
          "with-text-attachments",
          "with-unit-categories",
          "without-session-desc",
          "tp-export"
        ]
      }
    },
    "data": {
      "description": "Extra data sent to the exporter code, must be valid JSON.",
      "type": "object"
    }
  },
  "required": ["unit", "id", "entry_point", "file_extension"]
}
