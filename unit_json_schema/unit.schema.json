{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unit.schema.json",
  "title": "Checkbox Unit Schema",
  "description": "Schema that validates a Checkbox units",
  "if": {
    "not": { "required": ["unit"] }
  },
  "then": {
    "$ref": "job.schema.json"
  },
  "else": {
    "oneOf": [
      { "$ref": "job.schema.json" },
      { "$ref": "setup-job.schema.json" },
      { "$ref": "test-plan.schema.json" },
      { "$ref": "category.schema.json" },
      { "$ref": "template.schema.json" },
      { "$ref": "exporter.schema.json" },
      { "$ref": "manifest-entry.schema.json" },
      { "$ref": "packaging-meta-data.schema.json" }
    ],
    "discriminator": {
      "propertyName": "unit"
    }
  }
}
